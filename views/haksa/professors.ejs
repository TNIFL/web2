<div class="my-5">
    <h1 class="text-center">
        <%=title%>
    </h1>
    <div class="text-end mb-2">
        <a class="btn btn-primary px-3" href="/haksa/pro/insert">교수등록</a>
    </div>
    <table id="tbl" class="table table-striped table table-hover"></table>
    <script id="temp" type="text/x-handlebars-template">
    <tbody>
        {{#each .}}
            <tr>
                <td>{{PCODE}}</td>
                <td>{{PNAME}}</td>
                <td>{{DEPT}}</td>
                <td>{{TITLE}}</td>
                <td>{{FDATE}}</td>
                <td>{{FSALARY}}</td>
                <td><button pcode="{{PCODE}}" class="btn btn-outline-danger btn-sm delete">삭제</button></td>
            </tr>
        {{/each}}
    </tbody>
</script>
</div>
<script>
    getList();
    $("#tbl").on("click", ".delete", function() {
        const pcode=$(this).attr("pcode");
        if(confirm(`${pcode}번 교수를 삭제하실래요?`)) {
            $.ajax({
                type:"post",
                url:"/haksa/pro/delete",
                data:{pcode},
                success: function() {
                    alert("삭제가 완료되었습니다.");
                    getList();
                },
                error: function() {
                    alert("삭제가실패했스빈다.");
                }
            })
        }
    })
    function getList() {
        $.ajax({
            type: "get",
            url: "/haksa/pro/list.json",
            success: function (data) {
                console.log(data);
                const temp = Handlebars.compile($("#temp").html());
                $("#tbl").html(temp(data));
            }
        })
    }
</script>